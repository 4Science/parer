		<StrutturaOriginale>
			<TipoStruttura>DocumentoGenerico</TipoStruttura>
			<!--Valore standard-->
			<Componenti>
				<!--Come condiviso il documento principale (oggetto conservato) si compone di diversi file, a titolo di esempio ne sono stati inseriti 3-->
				<Componente>
					<ID>ID1</ID> <!--nome file-->
					<!--OBBLIGATORIO. È la chiave del file nel SIP e consente di ricongiungere il Componente al relativo file del SIP. Non è memorizzato nel Sistema e deve essere univoco all'interno dell'Indice SIP-->
					<OrdinePresentazione>1</OrdinePresentazione>
					<!--OBBLIGATORIO. Numero che indica l’ordine di successione del singolo Componente all’interno del Documento. Deve essere univoco e possibilmente sequenziale all’interno del Documento-->
					<TipoComponente>Contenuto</TipoComponente>
					<!--Valore standard-->
					<TipoSupportoComponente>FILE</TipoSupportoComponente>
					<!--Valore standard-->
					<NomeComponente>Prova.pdf</NomeComponente>
					<!--OBBLIGATORIO. Stringa che rappresenta il nome del file nei sistemi del produttore-->
					<FormatoFileVersato>PDF</FormatoFileVersato> <!--mettiamo l'estensione-->
					<!--OBBLIGATORIO. Rappresenta il formato del file-->
					<HashVersato>xxxxx</HashVersato>
					<!--Rappresenta l’hash del file. Il Sistema supporta i seguenti algoritmi di hash:
					- MD5 conforme alla specifica RFC 1321 (Rivest et al.) – come blocco di 16 byte – 128 bit
					- SHA-1 conforme alla specifica FIPS PUB 180-4 – come blocco di 20 byte – 160 bit
					- SHA-256 conforme alla specifica FIPS PUB 180-4 – come blocco di 32 byte – 256 bit-->
					<!-- prendere l'hash dall'oggetto s3 -->
				</Componente>
				<Componente>
					<ID>ID2</ID>
					<OrdinePresentazione>2</OrdinePresentazione>
					<TipoComponente>Contenuto</TipoComponente>
					<TipoSupportoComponente>FILE</TipoSupportoComponente>
